"use client";

import React, { useState, useMemo, useEffect, useCallback } from 'react';
import { motion, useScroll, useTransform, AnimatePresence, useSpring } from 'framer-motion';
import Image from 'next/image';

/**
 * Global smooth scroll handler compatible with Next.js App Router
 */
function scrollToSection(id: string) {
  const el = document.getElementById(id);
  const header = document.querySelector('header');
  if (!el) return;
  const offset = header ? header.getBoundingClientRect().height + 8 : 88;
  const top = el.getBoundingClientRect().top + window.scrollY - offset;
  window.scrollTo({ top, behavior: 'smooth' });
}

const Header = () => {
  const phoneNumber = "971527925100";
  const message = encodeURIComponent("Hello! I'd like to inquire about your services.");

  const [isOpen, setIsOpen] = useState(false);
  const [isDesktop, setIsDesktop] = useState(true);

  useEffect(() => {
    const checkRes = () => setIsDesktop(window.innerWidth >= 1024);
    checkRes();
    window.addEventListener('resize', checkRes, { passive: true });
    return () => window.removeEventListener('resize', checkRes);
  }, []);

  const { scrollY } = useScroll();
  
  const smoothY = useSpring(scrollY, { 
    stiffness: 120, 
    damping: 24, 
    mass: 0.1, 
    restDelta: 0.001 
  });

  const scrollRange = [0, 80];

  const logoMarginTop = useTransform(smoothY, [0, 80], isDesktop ? [12, 0] : [0, 0]);
  const headerScaleX = useTransform(smoothY, scrollRange, isDesktop ? [1, 0.94] : [1, 1]);
  const headerScaleY = useTransform(smoothY, scrollRange, isDesktop ? [1, 0.9] : [1, 1]);
  const headerYOffset = useTransform(smoothY, scrollRange, isDesktop ? [0, 16] : [0, 0]);
  const borderRadius = useTransform(smoothY, scrollRange, isDesktop ? ['0px', '40px'] : ['0px', '0px']);
  
// Set background to transparent on mobile regardless of scroll, 
  // while keeping the desktop scroll-to-opaque logic.
  const backgroundColor = useTransform(smoothY, scrollRange, 
    isDesktop 
      ? ['rgba(3, 3, 11, 0)', 'rgba(3, 3, 11, 0.85)'] 
      : ['rgba(0, 0, 0, 0)', 'rgba(0, 0, 0, 0)'] // Fully transparent on mobile
  );

  // Set border to transparent on mobile
  const borderColor = useTransform(smoothY, scrollRange, 
    isDesktop 
      ? ['rgba(255, 255, 255, 0)', 'rgba(255, 255, 255, 0.15)'] 
      : ['rgba(255, 255, 255, 0)', 'rgba(255, 255, 255, 0)'] // No border on mobile
  );

  // Remove blur on mobile
  const backdropFilter = useTransform(smoothY, scrollRange, 
    isDesktop 
      ? ['blur(0px)', 'blur(20px)'] 
      : ['blur(0px)', 'blur(0px)'] // No blur on mobile
  );

  const navLinks = useMemo(() => [
    { name: 'HOME',      href: '/',          id: 'hero'     },
    { name: 'ABOUT',     href: '#about',    id: 'about'    },
    { name: 'SERVICES',  href: '#services', id: 'services' },
    { name: 'LOCATIONS', href: '#map',      id: 'map'      },
    { name: 'CONTACT',   href: '#contact',  id: 'contact'  }
  ], []);

  const handleNavClick = useCallback((e: React.MouseEvent, id: string) => {
    e.preventDefault();
    setIsOpen(false);
    scrollToSection(id);
  }, []);

  // Shared Button Component for Desktop and Mobile Drawer
  const GetStartedButton = ({ className = "" }) => (
    <a
      href={`https://wa.me/${phoneNumber}?text=${message}`}
      target="_blank"
      rel="noopener noreferrer"
      className={`static-gradient-btn ${className}`}
    >
      <span className="btn-content">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="3" strokeLinecap="round" strokeLinejoin="round" className="mr-2">
          <path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/>
          <path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/>
          <path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>
        </svg>
        GET STARTED
      </span>
    </a>
  );

  return (
    <>
      <motion.header
        style={{ 
          width: '100%',
          y: headerYOffset, 
          scaleX: headerScaleX,
          scaleY: headerScaleY,
          borderRadius, 
          backgroundColor, 
          borderColor,
          backdropFilter,
          WebkitBackdropFilter: backdropFilter,
          x: '-50%',
          left: '50%',
          willChange: 'transform',
        }}
        className="fixed z-[100] lg:border flex items-center justify-between px-6 md:px-12 h-[72px] lg:h-[80px] pointer-events-auto origin-top"
      >
        {/* LOGO */}
        <motion.div 
          onClick={() => window.scrollTo({ top: 0, behavior: 'smooth' })}
          className="relative flex items-center group cursor-pointer shrink-0"
          style={{ marginTop: logoMarginTop }}
        >
          <div className="relative w-32 lg:w-40 h-12 lg:h-16 transition-transform duration-500 group-hover:scale-105">
             <Image 
                src="/4biz_logo-1.avif" 
                alt="4Biz International LLC" 
                fill
                priority
                className="object-contain"
              />
          </div>
        </motion.div>

        {/* DESKTOP NAVIGATION */}
        <nav className="hidden lg:flex items-center gap-10">
          {navLinks.map((link) => (
            <a 
              key={link.name} 
              href={link.href}
              onClick={(e) => handleNavClick(e, link.id)}
              className="text-[11px] uppercase tracking-[0.25em] font-black text-white/90 hover:text-cyan-400 transition-colors duration-300 relative group antialiased"
            >
              {link.name}
              <span className="absolute -bottom-1 left-0 w-0 h-[1.5px] bg-gradient-to-r from-[#00f2ff] to-[#bf00ff] transition-all duration-300 group-hover:w-full" />
            </a>
          ))}
        </nav>

        <div className="flex items-center gap-4">
          {/* DESKTOP ONLY BUTTON */}
          <div className="hidden lg:block">
            <GetStartedButton />
          </div>

{/* MOBILE TOGGLE — Replaced for exact symmetry */}
          <button 
            onClick={() => setIsOpen(!isOpen)} 
            className="lg:hidden relative w-10 h-10 flex flex-col items-center justify-center z-[110] touch-manipulation transform-gpu"
            aria-label="Toggle menu"
          >
            <div className="flex flex-col gap-[6px] items-center">
              <motion.span
                animate={isOpen ? { rotate: 45, y: 9 } : { rotate: 0, y: 0 }}
                transition={{ duration: 0.25, ease: 'easeInOut' }}
                className="w-[22px] h-[3px] bg-white block rounded-sm origin-center"
              />
              <motion.span
                animate={isOpen ? { opacity: 0, x: -8 } : { opacity: 1, x: 0 }}
                transition={{ duration: 0.2, ease: 'easeInOut' }}
                className="w-[22px] h-[3px] bg-white block rounded-sm"
              />
              <motion.span
                animate={isOpen ? { rotate: -45, y: -9 } : { rotate: 0, y: 0 }}
                transition={{ duration: 0.25, ease: 'easeInOut' }}
                className="w-[22px] h-[3px] bg-white block rounded-sm origin-center"
              />
            </div>
          </button>
        </div>
